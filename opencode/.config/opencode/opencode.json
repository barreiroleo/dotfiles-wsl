{
    "$schema": "https://opencode.ai/config.json",
    "tui": {
        "scroll_speed": 3
    },
    "permission": {
        "edit": "allow",
        "webfetch": "ask",
        "bash": {
            "*": "ask",
            "git status": "allow",
            "git diff": "allow",
            "ls": "allow",
            "pwd": "allow"
        }
    },
    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama (local)",
            "options": {
                "baseURL": "http://localhost:11434/v1"
            },
            "models": {
                "gpt-oss:latest": {
                    "name": "GPT-oss",
                    "tool" : true,
                    "reasoning": true,
                    "options": {
                        "reasoningEffort": "high",
                        "textVerbosity": "low",
                        "reasoningSummary": "auto",
                        "include": [
                            "reasoning.encrypted_content"
                        ]
                    }
                }
            }
        }
    }
}
